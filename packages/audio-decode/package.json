{
  "name": "audio-decode",
  "version": "3.11.2",
  "description": "Decode audio (wav, mp3, flac, ogg, opus, aac, …) to AudioBuffer — unscoped alias of @audio/decode",
  "type": "module",
  "sideEffects": false,
  "main": "audio-decode.js",
  "exports": {
    ".": "./audio-decode.js",
    "./stream": "./stream.js",
    "./meta": "./meta.js",
    "./package.json": "./package.json"
  },
  "files": [
    "audio-decode.js",
    "stream.js",
    "meta.js"
  ],
  "dependencies": {
    "@audio/decode": "^3.11.1"
  },
  "keywords": ["audio", "decode", "wav", "mp3", "flac", "ogg", "opus", "aac", "audiobuffer"],
  "license": "MIT",
  "author": "Dmitry Iv. <dfcreative@gmail.com>",
  "repository": { "type": "git", "url": "git+https://github.com/audiojs/decode.git", "directory": "packages/audio-decode" },
  "engines": { "node": ">=16" },
  "publishConfig": { "access": "public" }
}
