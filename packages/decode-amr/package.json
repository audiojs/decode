{
  "name": "@audio/decode-amr",
  "version": "1.2.1",
  "description": "Decode AMR-NB/WB audio via opencore-amr WASM",
  "type": "module",
  "main": "decode-amr.js",
  "types": "decode-amr.d.ts",
  "exports": {
    ".": "./decode-amr.js",
    "./audio": {
      "types": "./audio.d.ts",
      "default": "./audio.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "bash build.sh",
    "prepack": "npm run build",
    "test": "node test.js"
  },
  "files": [
    "decode-amr.js",
    "decode-amr.d.ts",
    "src/amr.wasm.cjs",
    "LICENSE",
    "audio.js",
    "audio.d.ts"
  ],
  "keywords": [
    "amr",
    "amr-nb",
    "amr-wb",
    "audio",
    "decode",
    "decoder",
    "wasm",
    "opencore-amr",
    "speech"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "Apache-2.0",
  "author": "audiojs",
  "homepage": "https://github.com/audiojs/decode-amr#readme",
  "bugs": "https://github.com/audiojs/decode-amr/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/audiojs/decode-amr.git"
  },
  "engines": {
    "node": ">=16"
  },
  "audio": "./audio.js"
}
