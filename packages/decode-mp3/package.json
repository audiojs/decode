{
  "name": "@audio/decode-mp3",
  "version": "1.2.1",
  "description": "Decode MP3 audio via mpg123 WASM — self-contained bundle",
  "type": "module",
  "main": "decode-mp3.js",
  "types": "decode-mp3.d.ts",
  "exports": {
    ".": "./decode-mp3.js",
    "./meta": "./meta.js",
    "./audio": {
      "types": "./audio.d.ts",
      "default": "./audio.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "decode-mp3.js",
    "decode-mp3.d.ts",
    "meta.js",
    "LICENSE",
    "audio.js",
    "audio.d.ts"
  ],
  "scripts": {
    "build": "bash build.sh",
    "prepack": "npm run build",
    "test": "node test.js"
  },
  "keywords": [
    "mp3",
    "mpeg",
    "audio",
    "decode",
    "decoder",
    "wasm",
    "mpg123"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "audiojs",
  "homepage": "https://github.com/audiojs/decode/tree/main/packages/decode-mp3#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/audiojs/decode.git",
    "directory": "packages/decode-mp3"
  },
  "dependencies": {
    "mpg123-decoder": "^1.0.3"
  },
  "engines": {
    "node": ">=18"
  },
  "audio": "./audio.js",
  "sideEffects": false
}
