{
  "name": "@audio/decode-wav",
  "version": "1.4.2",
  "description": "Decode WAV audio to PCM samples",
  "type": "module",
  "main": "decode-wav.js",
  "files": [
    "decode-wav.js",
    "meta.js",
    "audio.js",
    "audio.d.ts",
    "decode-wav.d.ts"
  ],
  "exports": {
    ".": "./decode-wav.js",
    "./meta": "./meta.js",
    "./audio": {
      "types": "./audio.d.ts",
      "default": "./audio.js"
    },
    "./package.json": "./package.json"
  },
  "keywords": [
    "wav",
    "audio",
    "decode",
    "decoder",
    "pcm"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "audiojs",
  "scripts": {
    "test": "node test.js"
  },
  "audio": "./audio.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/audiojs/decode.git",
    "directory": "packages/decode-wav"
  },
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "funding": "https://github.com/sponsors/audiojs",
  "types": "decode-wav.d.ts"
}
