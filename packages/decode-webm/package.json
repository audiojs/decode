{
  "name": "@audio/decode-webm",
  "version": "1.3.1",
  "description": "Decode WebM audio (Opus, Vorbis) to PCM samples",
  "type": "module",
  "main": "decode-webm.js",
  "types": "decode-webm.d.ts",
  "exports": {
    ".": "./decode-webm.js",
    "./audio": {
      "types": "./audio.d.ts",
      "default": "./audio.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "decode-webm.js",
    "decode-webm.d.ts",
    "LICENSE",
    "audio.js",
    "audio.d.ts"
  ],
  "dependencies": {
    "@wasm-audio-decoders/ogg-vorbis": "^0.1.20",
    "opus-decoder": "^0.7.6"
  },
  "keywords": [
    "webm",
    "matroska",
    "ebml",
    "opus",
    "vorbis",
    "audio",
    "decode",
    "decoder",
    "pcm"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "audiojs",
  "homepage": "https://github.com/audiojs/decode-webm#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/audiojs/decode-webm.git",
    "directory": "packages/decode-webm"
  },
  "engines": {
    "node": ">=18"
  },
  "bugs": "https://github.com/audiojs/decode-webm/issues",
  "scripts": {
    "build": "bash build.sh",
    "prepack": "npm run build",
    "test": "node test.js"
  },
  "audio": "./audio.js",
  "sideEffects": false
}
